{
  "name": "@prism/server",
  "version": "0.3.0",
  "description": "Personal Context MCP Server - Connects your knowledge graph to Claude Desktop and Cursor",
  "type": "module",
  "bin": {
    "prism-mcp": "./dist/apps/prism-server/src/mcp/index.js",
    "prism-setup": "./dist/apps/prism-server/src/cli/setup.js"
  },
  "scripts": {
    "dev": "DEV_MODE=true bun run --watch src/server.ts",
    "dev:prod-port": "bun run src/server.ts",
    "build": "tsc",
    "build:tauri": "bun build src/server.ts --compile --minify --sourcemap --outfile prism-server-bin",
    "prebuild:mcp": "bun test tests/unit/mcp-recall.test.ts --timeout 30000",
    "build:mcp": "bun build src/mcp/index.ts --compile --minify --outfile prism-mcp-bin",
    "postbuild:mcp": "./scripts/test-mcp-binary.sh",
    "test:mcp:unit": "bun test tests/unit/mcp-*.test.ts --timeout 30000",
    "test:mcp-binary": "./scripts/test-mcp-binary.sh",
    "test:mcp-binary:build": "./scripts/test-mcp-binary.sh --build",
    "smoke-test": "./scripts/smoke-test.sh",
    "start": "bun run src/server.ts",
    "mcp": "bun run src/mcp/index.ts",
    "setup": "bun run src/cli/setup.ts",
    "postinstall": "echo '\\n🔮 Run \"npm run setup\" to register Prism MCP with Claude Desktop / Cursor\\n'",
    "recall": "bun run src/cli/recall-cli.ts",
    "search": "bun run src/cli/search-cli.ts",
    "search-stats": "bun run src/cli/search-stats.ts",
    "gap-stats": "bun run src/cli/gap-stats.ts",
    "extract": "bun run src/cli/extract-cli.ts",
    "extraction": "bun run src/cli/extraction-cli.ts",
    "mark-batch0": "bun run src/cli/mark-batch0.ts",
    "seed": "bun run src/cli/seed-db.ts",
    "feedback-stats": "bun run src/cli/feedback-stats.ts",
    "find-duplicates": "bun run src/cli/find-duplicates.ts",
    "merge-entities": "bun run src/cli/merge-entities.ts",
    "snapshot": "bun run src/cli/snapshot-url.ts",
    "scout": "bun run src/cli/scout-cli.ts",
    "retype-entity": "bun run src/cli/retype-entity.ts",
    "delete-entity": "bun run src/cli/delete-entity.ts",
    "curator": "bun run src/cli/curator-cli.ts",
    "gardener": "bun run src/cli/gardener-cli.ts",
    "fix-finding-links": "bun run src/cli/fix-finding-links.ts",
    "migrate-v2": "bun run src/cli/schema-v2-migration.ts",
    "test": "bun test --timeout 60000 tests/db.test.ts tests/graph.test.ts tests/server.test.ts tests/api.test.ts tests/ingest.test.ts tests/pages.test.ts tests/ecs.test.ts tests/graph-link.test.ts tests/pipeline-integrity.test.ts tests/deep-explorer-strategies.test.ts tests/queue tests/integration tests/migrations tests/unit && bun test --timeout 60000 tests/atoms.test.ts && bun test --timeout 60000 tests/scout-enhancements.test.ts tests/gardener-automation.test.ts tests/deep-explorer-graph.test.ts",
    "test:queue": "bun test tests/queue --timeout 30000",
    "test:migrations": "bun test tests/migrations",
    "test:watch": "bun test --watch",
    "test:mcp": "./scripts/test-mcp-tools.sh",
    "test:mcp:build": "./scripts/test-mcp-tools.sh --build"
  },
  "dependencies": {
    "@prism/contract": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.3.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@mozilla/readability": "^0.5.0",
    "@tavily/core": "^0.0.2",
    "better-sqlite3": "^12.5.0",
    "chardet": "^2.0.0",
    "dompurify": "^3.1.6",
    "dotenv": "^17.2.3",
    "fastify": "^5.1.0",
    "html-to-text": "^9.0.5",
    "iconv-lite": "^0.6.3",
    "linkedom": "^0.18.4",
    "liteque": "^0.8.0",
    "mailparser": "^3.7.1",
    "openai": "^4.53.0",
    "pathe": "^1.1.2",
    "unpdf": "^1.4.0",
    "uuid": "^13.0.0",
    "zod": "^3.22.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/html-to-text": "^9.0.4",
    "@types/mailparser": "^3.4.4",
    "@types/node": "^20.10.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
