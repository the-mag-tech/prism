{
  "name": "@prism/client",
  "version": "0.1.0",
  "description": "Client abstraction layer for Prism Server - supports HTTP and local implementations",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./http": {
      "types": "./src/http.ts",
      "import": "./src/http.ts"
    },
    "./local": {
      "types": "./src/local.ts",
      "import": "./src/local.ts"
    }
  },
  "scripts": {
    "build": "echo 'No build needed - using TypeScript directly'",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}

